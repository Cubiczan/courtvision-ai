# CourtVision AI - environment variables
# Copy this file to .env and fill in your own values. Never commit .env.

# --- Qwen LLM (Alibaba Cloud DashScope) ---
# Optional. If unset, the app runs in offline/mock mode (see below) so pytest
# and a local demo work with ZERO credentials.
DASHSCOPE_API_KEY=your-dashscope-api-key
# Optional endpoint overrides (defaults shown in code)
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_FALLBACK_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- Offline / mock mode (three-tier data fallback: live -> cache -> mock) ---
# Any truthy value ("1"/"true"/"yes"/"on") forces offline mode even if a key
# is set. With no key present, offline mode is auto-detected.
# MOCK=1
# COURTVISION_OFFLINE=1
# Optional: override the local prediction cache dir / TTL (seconds).
# COURTVISION_CACHE_DIR=~/.cache/courtvision
# COURTVISION_CACHE_TTL=3600

# --- CHP decision gate ---
# Policy is read from ./policy.yaml (safe default used if the file is missing).

# --- Polygon Amoy / Azuro Protocol ---
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
AZURO_CORE_ADDRESS=0x0000000000000000000000000000000000000000
AZURO_PROXY_ADDRESS=0x0000000000000000000000000000000000000000

# --- Smart contract deployment (Hardhat) ---
# Private key of the deployer wallet. Use a dedicated testnet key only.
PRIVATE_KEY=your-testnet-private-key
POLYGONSCAN_API_KEY=your-polygonscan-api-key
